{
  "info": {
    "name": "MarquinhosBOT Games API",
    "description": "Coleção completa de endpoints da API de games do MarquinhosBOT",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Session Management",
      "description": "Gerenciamento de sessões de jogo",
      "item": [
        {
          "name": "List Active Sessions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bot_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/sessions?guildId={{guild_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "sessions"
              ],
              "query": [
                {
                  "key": "guildId",
                  "value": "{{guild_id}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Game Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{bot_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameType\": \"blackjack\",\n  \"guildId\": \"{{guild_id}}\",\n  \"channelId\": \"{{channel_id}}\",\n  \"hostId\": \"{{user_id}}\",\n  \"options\": {\n    \"difficulty\": \"medium\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/sessions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "sessions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Session Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bot_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/sessions/{{session_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "sessions",
                "{{session_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Join Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{bot_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{user_id}}\",\n  \"username\": \"Player1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/sessions/{{session_id}}/join",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "sessions",
                "{{session_id}}",
                "join"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Send Player Action",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{bot_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{user_id}}\",\n  \"type\": \"hit\",\n  \"data\": {}\n}"
            },
            "url": {
              "raw": "{{base_url}}/sessions/{{session_id}}/actions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "sessions",
                "{{session_id}}",
                "actions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "End Session",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bot_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/sessions/{{session_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "sessions",
                "{{session_id}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
