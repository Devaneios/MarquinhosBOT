  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-generate session ID if not set",
          "if (!pm.environment.get('session_id')) {",
          "    const uuid = require('uuid');",
          "    pm.environment.set('session_id', uuid.v4());",
          "}",
          "",
          "// Set timestamp for requests",
          "pm.environment.set('timestamp', new Date().toISOString());"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test for all requests",
          "pm.test('Status code is successful', function () {",
          "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
          "});",
          "",
          "// Save session ID from create session response",
          "if (pm.info.requestName === 'Create Game Session' && pm.response.code === 201) {",
          "    const responseJson = pm.response.json();",
          "    pm.environment.set('session_id', responseJson.id);",
          "    console.log('Session ID saved:', responseJson.id);",
          "}",
          "",
          "// Log response for debugging",
          "console.log('Response:', pm.response.json());"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://discord-bot/api/games",
      "description": "Base URL for the Games API"
    },
    {
      "key": "bot_token",
      "value": "YOUR_BOT_TOKEN_HERE",
      "description": "Discord Bot Token"
    },
    {
      "key": "guild_id",
      "value": "123456789012345678",
      "description": "Discord Guild (Server) ID"
    },
    {
      "key": "channel_id",
      "value": "123456789012345678",
      "description": "Discord Channel ID"
    },
    {
      "key": "user_id",
      "value": "123456789012345678",
      "description": "Discord User ID"
    },
    {
      "key": "session_id",
      "value": "",
      "description": "Game Session ID (auto-generated)"
    },
    {
      "key": "game_type",
      "value": "blackjack",
      "description": "Type of game to interact with"
    }
  ]
